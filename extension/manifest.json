{
  "manifest_version": 3,
  "name": "HumanOS Tracker",
  "version": "1.0.0",
  "description": "Tracks browser behavior for HumanOS.",
  "permissions": ["tabs", "activeTab", "scripting"],
  "host_permissions": ["http://localhost:5000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "HumanOS Tracker"
  }
}